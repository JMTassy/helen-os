{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile"
  },
  "deploy": {
    "startCommand": "gunicorn -w 4 -b 0.0.0.0:$PORT helen_os.api_server:create_app()",
    "restartPolicyCondition": "on-failure",
    "restartPolicyMaxRetries": 5
  },
  "env": {
    "PORT": {
      "description": "Server port",
      "value": "8000"
    }
  }
}
